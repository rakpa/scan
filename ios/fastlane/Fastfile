# fastlane release lane for the Flutter app on CI.
# cert + sigh via App Store Connect API, then `flutter build ipa` (handles Dart compile/assets).

default_platform(:ios)

APP_ID = ENV["BUNDLE_ID"] || "com.scanella.mobile"

platform :ios do
  desc "Build and export a signed App Store IPA"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"]
    )

    keychain_name = "ci-signing"
    keychain_password = "ci-signing-pass"
    keychain_db = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
    delete_keychain(name: keychain_name) if File.exist?(keychain_db)
    create_keychain(
      name: keychain_name, password: keychain_password,
      default_keychain: true, unlock: true, timeout: 3600, lock_when_sleeps: false
    )

    cert(api_key: api_key, keychain_path: keychain_db, keychain_password: keychain_password)
    sigh(api_key: api_key, app_identifier: APP_ID, platform: "ios")
    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      path: "Runner.xcodeproj",
      use_automatic_signing: false,
      team_id: ENV["TEAM_ID"],
      bundle_identifier: APP_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["Runner"]
    )

    export_plist = File.expand_path("ExportOptions.plist")
    File.write(
      export_plist,
      <<~PLIST,
        <?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
        <plist version="1.0">
        <dict>
          <key>method</key>
          <string>app-store</string>
          <key>signingStyle</key>
          <string>manual</string>
          <key>teamID</key>
          <string>#{ENV['TEAM_ID']}</string>
          <key>provisioningProfiles</key>
          <dict>
            <key>#{APP_ID}</key>
            <string>#{profile_name}</string>
          </dict>
        </dict>
        </plist>
      PLIST
    )

    # Flutter owns the Xcode build scripts (Dart compile, assets, icons).
    sh(
      "cd .. && flutter build ipa --release " \
      "--build-number=#{ENV['BUILD_NUMBER']} --build-name=1.0.0 " \
      "--export-options-plist=ios/ExportOptions.plist"
    )

    sh("mkdir -p ../build/ipa")
    sh("cp ../build/ios/ipa/*.ipa ../build/ipa/ScanMaster.ipa")

    if ENV["UPLOAD_TESTFLIGHT"] == "true"
      upload_to_testflight(
        api_key: api_key,
        ipa: "../build/ipa/ScanMaster.ipa",
        skip_waiting_for_build_processing: true
      )
    end
  end
end
