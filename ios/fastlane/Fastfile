# fastlane release lane for the Flutter app on CI.
# Reuses a stored distribution cert (GitHub secret) to avoid Apple's 2–3 cert limit.
# cert + sigh via App Store Connect API, then `flutter build ipa`.

require "base64"

default_platform(:ios)

APP_ID = ENV["BUNDLE_ID"] || "com.scanella.mobile"
CERT_EXPORT_PASSWORD = ENV["IOS_DIST_CERT_PASSWORD"] || "scan-ci-export"

platform :ios do
  desc "Build and export a signed App Store IPA"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"]
    )

    keychain_name = "ci-signing"
    keychain_password = "ci-signing-pass"
    keychain_db = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
    delete_keychain(name: keychain_name) if File.exist?(keychain_db)
    create_keychain(
      name: keychain_name, password: keychain_password,
      default_keychain: true, unlock: true, timeout: 3600, lock_when_sleeps: false
    )

    p12_secret = ENV["IOS_DIST_CERT_P12_BASE64"].to_s.strip
    if p12_secret.length.positive?
      UI.message("Importing distribution certificate from IOS_DIST_CERT_P12_BASE64 secret...")
      p12_path = File.expand_path("imported_dist.p12")
      File.binwrite(p12_path, Base64.decode64(p12_secret))
      import_certificate(
        certificate_path: p12_path,
        certificate_password: ENV["IOS_DIST_CERT_PASSWORD"],
        keychain_name: keychain_name,
        keychain_password: keychain_password
      )
    else
      UI.important(
        "No IOS_DIST_CERT_P12_BASE64 secret — requesting cert from Apple. " \
        "If this fails with 'maximum certificates', revoke orphaned Distribution certs at " \
        "developer.apple.com → Certificates, then re-run."
      )
      cert(
        api_key: api_key,
        keychain_path: keychain_db,
        keychain_password: keychain_password,
        force: false
      )
      # Export for the user to save as GitHub secret so future runs reuse this cert.
      export_path = File.expand_path("../build/dist_cert.p12")
      sh("mkdir -p ../build")
      identity = sh(
        "security find-identity -v -p codesigning '#{keychain_db}' " \
        "| grep 'Apple Distribution' | head -1 " \
        "| sed -E 's/^[[:space:]]*[0-9]+[[:space:]]+\\*?([A-F0-9]+)[[:space:]]+.*/\\1/'",
        log: false
      ).strip
      UI.user_error!("No Apple Distribution identity found in keychain") if identity.empty?
      sh(
        "security export -k '#{keychain_db}' -P '#{keychain_password}' " \
        "-t identities -f pkcs12 -p '#{CERT_EXPORT_PASSWORD}' " \
        "-o '#{export_path}' #{identity}"
      )
      UI.success(
        "Exported dist_cert.p12 — download the ios-dist-cert artifact and add " \
        "IOS_DIST_CERT_P12_BASE64 + IOS_DIST_CERT_PASSWORD secrets to avoid hitting Apple's cert limit."
      )
    end

    sigh(api_key: api_key, app_identifier: APP_ID, platform: "ios")
    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      path: "Runner.xcodeproj",
      use_automatic_signing: false,
      team_id: ENV["TEAM_ID"],
      bundle_identifier: APP_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["Runner"]
    )

    export_plist = File.expand_path("ExportOptions.plist")
    File.write(
      export_plist,
      <<~PLIST,
        <?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
        <plist version="1.0">
        <dict>
          <key>method</key>
          <string>app-store</string>
          <key>signingStyle</key>
          <string>manual</string>
          <key>teamID</key>
          <string>#{ENV['TEAM_ID']}</string>
          <key>provisioningProfiles</key>
          <dict>
            <key>#{APP_ID}</key>
            <string>#{profile_name}</string>
          </dict>
        </dict>
        </plist>
      PLIST
    )

    sh(
      "cd .. && flutter build ipa --release " \
      "--build-number=#{ENV['BUILD_NUMBER']} --build-name=1.0.0 " \
      "--export-options-plist=ios/ExportOptions.plist"
    )

    sh("mkdir -p ../build/ipa")
    sh("cp ../build/ios/ipa/*.ipa ../build/ipa/ScanMaster.ipa")

    if ENV["UPLOAD_TESTFLIGHT"] == "true"
      upload_to_testflight(
        api_key: api_key,
        ipa: "../build/ipa/ScanMaster.ipa",
        skip_waiting_for_build_processing: true
      )
    end
  end
end
