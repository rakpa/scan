<?xml version="1.0" encoding="utf-8"?>
<!-- The logo mark used by the Android 12+ splash screen: navy rounded square
     + the document glyph. Sized within the adaptive-icon safe zone so it isn't
     clipped. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="@color/logoNavy" />
            <corners android:radius="26dp" />
            <size android:width="108dp" android:height="108dp" />
        </shape>
    </item>
    <item
        android:drawable="@drawable/logo_glyph"
        android:gravity="center"
        android:width="108dp"
        android:height="108dp" />
</layer-list>
